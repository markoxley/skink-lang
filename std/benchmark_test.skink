// Module benchmark_test contains unit tests for the std/benchmark module.
module benchmark_test

import "std/benchmark"
import "testing"

// TestNewB verifies benchmark creation.
pub fn TestNewB() {
    b := benchmark.NewB("foo")
    if b.N() != 1 {
        Errorf("NewB default N should be 1")
    }
}

// TestSetN verifies iteration count can be changed.
pub fn TestSetN() {
    b := benchmark.NewB("foo")
    b.SetN(100)
    if b.N() != 100 {
        Errorf("SetN should update iteration count")
    }
}

// TestTimerSmoke verifies StartTimer and StopTimer run without panic.
pub fn TestTimerSmoke() {
    b := benchmark.NewB("foo")
    b.StartTimer()
    b.StopTimer()
    b.Report()
}
