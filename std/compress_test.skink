// Module compress_test contains unit tests for the std/compress module.
// The compression implementations are placeholders; tests verify
// structural correctness without checking real compression ratios.
module compress_test

import "std/compress"
import "testing"

// TestGzipWriterCreate verifies that a GzipWriter can be created and
// written to without crashing.
pub fn TestGzipWriterCreate() {
    gw := compress.NewGzipWriter(6)
    n, err := gw.Write("hello", 5)
    if err.message != "" {
        Errorf("GzipWriter Write returned unexpected error")
    }
    if n != 5 {
        Errorf("GzipWriter Write should return bytes written")
    }
    _, cerr := gw.Close()
    if cerr.message != "" {
        Errorf("GzipWriter Close returned unexpected error")
    }
}

// TestDeflaterCompress verifies that Deflater.Compress returns compressed data.
pub fn TestDeflaterCompress() {
    d := compress.Deflater{windowBits: 15, memLevel: 8}
    out, outLen := d.Compress("abc", 3)
    if out == "" {
        Errorf("Deflater should return non-empty output")
    }
    if outLen == 0 {
        Errorf("Deflater should return positive length")
    }
}

// TestInflaterDecompress verifies that Inflater.Decompress returns data.
pub fn TestInflaterDecompress() {
    d := compress.Deflater{windowBits: 15, memLevel: 8}
    compressed, compLen := d.Compress("abc", 3)
    i := compress.Inflater{}
    out := i.Decompress(compressed, compLen, 12)
    if out == "" {
        Errorf("Inflater should return non-empty output")
    }
}

// TestDeflaterInflaterRoundtrip verifies compression and decompression roundtrip.
pub fn TestDeflaterInflaterRoundtrip() {
    data := "hello world"
    d := compress.Deflater{windowBits: 15, memLevel: 8}
    compressed, compLen := d.Compress(data, 11)
    if compressed == "" || compLen == 0 {
        Errorf("Compress should produce non-empty output")
    }
    i := compress.Inflater{}
    decompressed := i.Decompress(compressed, compLen, 11)
    if decompressed == "" {
        Errorf("Decompress should return non-empty output")
    }
}

// TestDeflaterEmptyData verifies compression of empty data.
pub fn TestDeflaterEmptyData() {
    d := compress.Deflater{windowBits: 15, memLevel: 8}
    compressed, compLen := d.Compress("", 0)
    if compressed == "" && compLen == 0 {
        Errorf("Compress of empty data should not crash")
    }
}

// TestGzipWriterEmpty verifies GzipWriter with no data.
pub fn TestGzipWriterEmpty() {
    gw := compress.NewGzipWriter(6)
    _, cerr := gw.Close()
    if cerr.message != "" {
        Errorf("GzipWriter Close with no data should not error")
    }
}

// TestInflaterEmptyData verifies Inflater handles empty data without crashing.
pub fn TestInflaterEmptyData() {
    i := compress.Inflater{}
    out := i.Decompress("", 0, 1)
    if str.Equal(out, "") == false {
        Errorf("Inflater empty data should return empty output")
    }
}
