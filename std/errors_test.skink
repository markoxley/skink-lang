// Module errors_test contains unit tests for the std/errors module.
module errors_test

import "std/errors"
import "std/str"
import "testing"

// TestNew verifies error creation with a message.
pub fn TestNew() {
    err := errors.New("something failed")
    if str.Equal(err.String(), "something failed") == false {
        Errorf("New error message should match")
    }
}

// TestIs verifies equality comparison.
pub fn TestIs() {
    a := errors.New("fail")
    b := errors.New("fail")
    c := errors.New("other")
    if errors.Is(a, b) == false {
        Errorf("Identical errors should be equal")
    }
    if errors.Is(a, c) == true {
        Errorf("Different errors should not be equal")
    }
}

// TestWrap verifies prefix wrapping.
pub fn TestWrap() {
    err := errors.New("inner")
    wrapped := errors.Wrap(err, "outer")
    if str.Contains(wrapped.String(), "outer") == false {
        Errorf("Wrap should include the prefix")
    }
    if str.Contains(wrapped.String(), "inner") == false {
        Errorf("Wrap should include the original message")
    }
}
fn test() -> (int, errors.Error) {
    return 0, nil
}

fn test2() -> (int, errors.Error) {
    v, err := test()?
}
