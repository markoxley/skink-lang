// Module fmt_test contains unit tests for the std/fmt module.
module fmt_test

import "std/fmt"
import "std/str"
import "testing"

// TestItoa verifies integer to string conversion.
pub fn TestItoa() {
    s := fmt.Itoa(42)
    if str.Equal(s, "42") == false {
        Errorf("Itoa(42) should be 42")
    }
}

// TestItoaNegative verifies negative integer conversion.
pub fn TestItoaNegative() {
    s := fmt.Itoa(-7)
    if str.Equal(s, "-7") == false {
        Errorf("Itoa(-7) should be -7")
    }
}

// TestFtoa verifies float to string conversion.
pub fn TestFtoa() {
    s := fmt.Ftoa(3.14)
    if str.Contains(s, "3") == false {
        Errorf("Ftoa(3.14) should contain 3")
    }
    if str.Contains(s, ".") == false {
        Errorf("Ftoa should contain a decimal point")
    }
}

// TestBtoaTrue verifies bool true conversion.
pub fn TestBtoaTrue() {
    s := fmt.Btoa(true)
    if str.Equal(s, "true") == false {
        Errorf("Btoa(true) should be true")
    }
}

// TestBtoaFalse verifies bool false conversion.
pub fn TestBtoaFalse() {
    s := fmt.Btoa(false)
    if str.Equal(s, "false") == false {
        Errorf("Btoa(false) should be false")
    }
}

// TestSprintf1s verifies string formatting.
pub fn TestSprintf1s() {
    s := fmt.Sprintf1s("hello {}", "world")
    if str.Equal(s, "hello world") == false {
        Errorf("Sprintf1s should replace placeholder with string")
    }
}

// TestSprintf1f verifies float formatting.
pub fn TestSprintf1f() {
    s := fmt.Sprintf1f("pi is {}", 3.14)
    if str.Contains(s, "3") == false {
        Errorf("Sprintf1f should include formatted float")
    }
}

// TestSprintf1b verifies bool formatting.
pub fn TestSprintf1b() {
    s := fmt.Sprintf1b("flag is {}", true)
    if str.Equal(s, "flag is true") == false {
        Errorf("Sprintf1b should replace with true")
    }
}

// TestSprintf2 verifies formatting with two int arguments.
pub fn TestSprintf2() {
    s := fmt.Sprintf2("{} and {}", 1, 2)
    if str.Equal(s, "1 and 2") == false {
        Errorf("Sprintf2 should replace both placeholders")
    }
}
