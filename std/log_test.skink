// Module log_test contains unit tests for the std/log module.
module log_test

import "std/log"
import "std/str"
import "testing"

// TestNewLogger verifies logger creation.
pub fn TestNewLogger() {
    l := log.NewLogger("[TEST] ")
    l.Print("hello")
}

// TestLoggerPrintf verifies formatted logging does not panic.
pub fn TestLoggerPrintf() {
    l := log.NewLogger("")
    l.Printf("value {}", 42)
}
