// Module mqtt_test contains unit tests for the std/mqtt module.
module mqtt_test

import "std/mqtt"
import "testing"

// TestNewClient verifies that NewClient creates a client with the correct host and port.
pub fn TestNewClient() {
    client, err := mqtt.NewClient("test_client", "127.0.0.1", 1883)
    if err.message != "" {
        Errorf("NewClient should not error")
    }
    if client.host != "127.0.0.1" {
        Errorf("NewClient host should be 127.0.0.1")
    }
    if client.port != 1883 {
        Errorf("NewClient port should be 1883")
    }
    client.Close()
}

// TestConnectInvalid verifies Connect returns error for invalid context.
pub fn TestConnectInvalid() {
    var client mqtt.Client
    err := client.Connect()
    if err.message == "" {
        Errorf("Connect on invalid client should error")
    }
}

// TestPublishInvalid verifies Publish returns error for invalid context.
pub fn TestPublishInvalid() {
    var client mqtt.Client
    err := client.Publish("topic", "payload", 0)
    if err.message == "" {
        Errorf("Publish on invalid client should error")
    }
}

// TestSubscribeInvalid verifies Subscribe returns error for invalid context.
pub fn TestSubscribeInvalid() {
    var client mqtt.Client
    err := client.Subscribe("topic", 0)
    if err.message == "" {
        Errorf("Subscribe on invalid client should error")
    }
}

// TestDisconnectInvalid verifies Disconnect returns error for invalid context.
pub fn TestDisconnectInvalid() {
    var client mqtt.Client
    err := client.Disconnect()
    if err.message == "" {
        Errorf("Disconnect on invalid client should error")
    }
}
