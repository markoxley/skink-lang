// Module reader_test tests the Reader template with a concrete buf.Buffer.
module reader_test

import "std/reader"
import "std/buf"
import "std/libc"
import "std/str"
import "testing"

// TestReadAll verifies reader.ReadAll with a buf.Buffer.
pub fn TestReadAll() {
    b := buf.NewBuffer()
    b.WriteString("hello world")
    result := reader.ReadAll(&b)
    b.Free()
    if str.Equal(result, "hello world") == false {
        Errorf("ReadAll should return full buffer contents")
    }
    libc.free(result)
}

// TestReadAtLeast verifies reader.ReadAtLeast.
pub fn TestReadAtLeast() {
    b := buf.NewBuffer()
    b.WriteString("abcdef")
    dst := libc.malloc(10)
    n := reader.ReadAtLeast(&b, dst, 3, 10)
    b.Free()
    if n < 3 {
        Errorf("ReadAtLeast should read at least 3 bytes")
    }
    libc.free(dst)
}
