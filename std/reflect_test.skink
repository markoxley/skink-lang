// Module reflect_test contains unit tests for the std/reflect module.
module reflect_test

import "std/reflect"
import "std/str"
import "testing"

// TestTypeOfSize verifies TypeOf returns correct size via sizeof(T).
pub fn TestTypeOfSize() {
    t := reflect.TypeOf<int>(42)
    if t.size != sizeof(int) {
        Errorf("TypeOf<int> size should match sizeof(int)")
    }

    t2 := reflect.TypeOf<int64>(int64(42))
    if t2.size != sizeof(int64) {
        Errorf("TypeOf<int64> size should match sizeof(int64)")
    }
}

struct TestStruct {
    b: bool
    i: int
    i64: int64
    s: string
    f: float
}

// TestFieldAccess verifies Get/Set functions via manually created Field descriptors.
pub fn TestFieldAccess() {
    val := TestStruct{b: true, i: 42, i64: int64(100), s: "hello", f: 3.14}
    ptr := int64(&val)

    // bool at offset 0
    fBool := reflect.Field{name: "b", type_name: "bool", offset: 0}
    if reflect.GetBool(ptr, fBool) != true {
        Errorf("Field b should be true")
    }
    reflect.SetBool(ptr, fBool, false)
    if val.b != false {
        Errorf("Field b should have been set to false")
    }

    // int at offset 4 (after bool + 3 padding bytes)
    fInt := reflect.Field{name: "i", type_name: "int", offset: 4}
    if reflect.GetInt(ptr, fInt) != 42 {
        Errorf("Field i should be 42")
    }
    reflect.SetInt(ptr, fInt, 43)
    if val.i != 43 {
        Errorf("Field i should have been set to 43")
    }

    // int64 at offset 8
    fInt64 := reflect.Field{name: "i64", type_name: "int64", offset: 8}
    if reflect.GetInt64(ptr, fInt64) != int64(100) {
        Errorf("Field i64 should be 100")
    }
    reflect.SetInt64(ptr, fInt64, int64(200))
    if val.i64 != int64(200) {
        Errorf("Field i64 should have been set to 200")
    }

    // string at offset 16
    fStr := reflect.Field{name: "s", type_name: "string", offset: 16}
    if str.Equal(reflect.GetString(ptr, fStr), "hello") == false {
        Errorf("Field s should be hello")
    }
    reflect.SetString(ptr, fStr, "world")
    if str.Equal(val.s, "world") == false {
        Errorf("Field s should have been set to world")
    }

    // float at offset 24
    fFloat := reflect.Field{name: "f", type_name: "float", offset: 24}
    if reflect.GetFloat(ptr, fFloat) != 3.14 {
        Errorf("Field f should be 3.14")
    }
    reflect.SetFloat(ptr, fFloat, 2.71)
    if val.f != 2.71 {
        Errorf("Field f should have been set to 2.71")
    }
}

// TestHash verifies reflect.Hash.
pub fn TestHash() {
    s := "hello"
    h1 := reflect.Hash(int64(&s), "string")
    h2 := reflect.Hash(int64(&s), "string")
    if h1 != h2 {
        Errorf("Hashes of same string should be equal")
    }

    i := 42
    hi := reflect.Hash(int64(&i), "int")
    if hi < 0 {
        Errorf("Hash should be non-negative")
    }
}
