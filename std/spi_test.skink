// Module spi_test contains unit tests for std/spi.
// Hardware-specific tests are stubs; these verify API structure.
module spi_test

import "std/spi"
import "std/libc"
import "std/str"
import "testing"

// TestOpen verifies SPI device creation.
pub fn TestOpen() {
    dev, err := spi.Open(0, 0, 1000000, 0)
    if err.message != "" {
        Errorf("Open should return empty error")
    }
    if dev.fd == 0 {
        Errorf("Open should set non-zero fd")
    }
}

// TestTransfer verifies SPI transfer.
pub fn TestTransfer() {
    dev, _ := spi.Open(0, 0, 1000000, 0)
    rx, err := dev.Transfer("abc", 3)
    if err.message != "" {
        Errorf("Transfer should return empty error")
    }
    if str.Equal(rx, "abc") == false {
        Errorf("Transfer stub should echo tx data")
    }
    libc.free(rx)
    dev.Close()
}

// TestWrite verifies Write returns requested length.
pub fn TestWrite() {
    dev, _ := spi.Open(0, 0, 1000000, 0)
    n := dev.Write("xyz", 3)
    if n != 3 {
        Errorf("Write should return 3")
    }
    dev.Close()
}

// TestRead verifies Read returns data.
pub fn TestRead() {
    dev, _ := spi.Open(0, 0, 1000000, 0)
    data, err := dev.Read(4)
    if err.message != "" {
        Errorf("Read should return empty error")
    }
    data[0] = 1
    if data[0] != 1 {
        Errorf("Read should return writable data pointer")
    }
    libc.free(data)
    dev.Close()
}

// TestClose verifies Close is idempotent.
pub fn TestClose() {
    dev, _ := spi.Open(0, 0, 1000000, 0)
    err := dev.Close()
    if err.message != "" {
        Errorf("Close should return empty error")
    }
    err2 := dev.Close()
    if err2.message != "" {
        Errorf("double Close should return empty error")
    }
}
