// Module streams_test contains unit tests for the std/streams module.
// Full testing requires concrete Reader and Writer implementations.
module streams_test

import "std/streams"
import "std/buf"
import "testing"

// TestLimitReaderCreation verifies a LimitReader can be constructed.
pub fn TestLimitReaderCreation() {
    // Dummy reader (zero-value satisfies template for compilation)
    lr := streams.LimitReader{n: 100}
    if lr.n != 100 {
        Errorf("LimitReader should store the limit")
    }
}

// TestTeeReaderCreation verifies a TeeReader can be constructed.
pub fn TestTeeReaderCreation() {
    tr := streams.TeeReader{}
    if tr.r.Read != nil {
        // Template fields are zero-initialised; this mainly checks compilation.
    }
}

