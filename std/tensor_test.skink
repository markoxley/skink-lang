// Module tensor_test contains unit tests for the std/tensor module.
module tensor_test

import "std/tensor"
import "testing"

// TestZeros verifies Zeros creates a tensor filled with 0.
pub fn TestZeros() {
    t := tensor.Zeros([2, 3])
    if t.Rank() != 2 {
        Errorf("Zeros([2,3]) should have rank 2")
    }
    if len(t.Shape()) != 2 {
        Errorf("Shape length should be 2")
    }
    if t.Shape()[0] != 2 {
        Errorf("First dimension should be 2")
    }
    if t.Shape()[1] != 3 {
        Errorf("Second dimension should be 3")
    }
    if t.Get([0, 0]) != 0.0 {
        Errorf("Zeros tensor should contain 0")
    }
}

// TestOnes verifies Ones creates a tensor filled with 1.
pub fn TestOnes() {
    t := tensor.Ones([2, 2])
    if t.Get([0, 0]) != 1.0 {
        Errorf("Ones tensor should contain 1")
    }
    if t.Get([1, 1]) != 1.0 {
        Errorf("Ones tensor should contain 1 everywhere")
    }
}

// TestSetGet verifies element-wise Set and Get.
pub fn TestSetGet() {
    t := tensor.Zeros([2, 2])
    t.Set([1, 0], 5.0)
    if t.Get([1, 0]) != 5.0 {
        Errorf("Set then Get should return the stored value")
    }
    if t.Get([0, 0]) != 0.0 {
        Errorf("Unset element should remain 0")
    }
}

// TestAdd verifies element-wise addition.
pub fn TestAdd() {
    a := tensor.Ones([2, 2])
    b := tensor.Ones([2, 2])
    c := tensor.Add(a, b)
    if c.Get([0, 0]) != 2.0 {
        Errorf("Add of two Ones should yield 2")
    }
}

// TestSub verifies element-wise subtraction.
pub fn TestSub() {
    a := tensor.Ones([2, 2])
    b := tensor.Ones([2, 2])
    c := tensor.Sub(a, b)
    if c.Get([0, 0]) != 0.0 {
        Errorf("Sub of identical tensors should yield 0")
    }
}

// TestMul verifies element-wise multiplication.
pub fn TestMul() {
    a := tensor.Ones([2, 2])
    b := tensor.Ones([2, 2])
    c := tensor.Mul(a, b)
    if c.Get([0, 0]) != 1.0 {
        Errorf("Mul of two Ones should yield 1")
    }
}

// TestScale verifies scalar multiplication.
pub fn TestScale() {
    a := tensor.Ones([2, 2])
    c := tensor.Scale(a, 3.0)
    if c.Get([0, 0]) != 3.0 {
        Errorf("Scale by 3 should yield 3")
    }
}

// TestSum verifies Sum of all elements.
pub fn TestSum() {
    a := tensor.Ones([3, 3])
    s := tensor.Sum(a)
    if s != 9.0 {
        Errorf("Sum of 3x3 Ones should be 9")
    }
}

// TestMatMul verifies matrix multiplication.
pub fn TestMatMul() {
    a := tensor.Ones([2, 3])
    b := tensor.Ones([3, 4])
    c := tensor.MatMul(a, b)
    if c.Shape()[0] != 2 {
        Errorf("MatMul result rows should match A rows")
    }
    if c.Shape()[1] != 4 {
        Errorf("MatMul result cols should match B cols")
    }
    if c.Get([0, 0]) != 3.0 {
        Errorf("MatMul of Ones should sum inner dimension")
    }
}

// TestTranspose verifies Transpose swaps dimensions.
pub fn TestTranspose() {
    a := tensor.Zeros([2, 3])
    a.Set([0, 1], 7.0)
    b := tensor.Transpose(a)
    if b.Shape()[0] != 3 {
        Errorf("Transpose should swap rows and cols")
    }
    if b.Shape()[1] != 2 {
        Errorf("Transpose should swap rows and cols")
    }
    if b.Get([1, 0]) != 7.0 {
        Errorf("Transpose should move values correctly")
    }
}

// TestReLU verifies ReLU zeroes negative values.
pub fn TestReLU() {
    a := tensor.Zeros([2, 2])
    a.Set([0, 0], -1.0)
    a.Set([0, 1], 2.0)
    c := tensor.ReLU(a)
    if c.Get([0, 0]) != 0.0 {
        Errorf("ReLU should zero negative values")
    }
    if c.Get([0, 1]) != 2.0 {
        Errorf("ReLU should preserve positive values")
    }
}

// TestRandom verifies Random creates a tensor with the correct shape.
pub fn TestRandom() {
    t := tensor.Random([2, 3])
    if t.Rank() != 2 {
        Errorf("Random should have correct rank")
    }
    if t.Shape()[0] != 2 {
        Errorf("Random first dim should be 2")
    }
    if t.Shape()[1] != 3 {
        Errorf("Random second dim should be 3")
    }
}

// TestSigmoid verifies sigmoid(0) == 0.5.
pub fn TestSigmoid() {
    a := tensor.Zeros([1, 1])
    s := tensor.Sigmoid(a)
    val := s.Get([0, 0])
    if val < 0.49 || val > 0.51 {
        Errorf("Sigmoid(0) should be ~0.5")
    }
}

// TestTanh verifies tanh(0) == 0.
pub fn TestTanh() {
    a := tensor.Zeros([1, 1])
    t := tensor.Tanh(a)
    if t.Get([0, 0]) != 0.0 {
        Errorf("Tanh(0) should be 0")
    }
}

// TestSoftmax verifies probabilities sum to 1.
pub fn TestSoftmax() {
    a := tensor.Zeros([1, 3])
    a.Set([0, 0], 1.0)
    a.Set([0, 1], 2.0)
    a.Set([0, 2], 3.0)
    s := tensor.Softmax(a)
    sum := s.Get([0, 0]) + s.Get([0, 1]) + s.Get([0, 2])
    if sum < 0.99 || sum > 1.01 {
        Errorf("Softmax probabilities should sum to ~1")
    }
}

// TestLinearLayer verifies Forward produces correct shape.
pub fn TestLinearLayer() {
    layer := tensor.NewLinear(3, 2)
    input := tensor.Ones([1, 3])
    out := layer.Forward(input)
    if out.Shape()[0] != 1 {
        Errorf("LinearLayer output batch should be 1")
    }
    if out.Shape()[1] != 2 {
        Errorf("LinearLayer output features should match outFeatures")
    }
}

// TestConv2DLayer verifies Forward produces correct shape.
pub fn TestConv2DLayer() {
    layer := tensor.NewConv2D(1, 4, 3, 1)
    input := tensor.Zeros([1, 1, 8, 8])
    out := layer.Forward(input)
    if out.Shape()[0] != 1 {
        Errorf("Conv2DLayer output batch should be 1")
    }
    if out.Shape()[1] != 4 {
        Errorf("Conv2DLayer output channels should match outChannels")
    }
    if out.Shape()[2] != 6 {
        Errorf("Conv2DLayer output height should be 6")
    }
    if out.Shape()[3] != 6 {
        Errorf("Conv2DLayer output width should be 6")
    }
}

// TestMaxPool2D verifies Forward produces correct shape.
pub fn TestMaxPool2D() {
    pool := tensor.NewMaxPool2D(2, 2)
    input := tensor.Zeros([1, 1, 4, 4])
    out := pool.Forward(input)
    if out.Shape()[0] != 1 {
        Errorf("MaxPool2D output batch should be 1")
    }
    if out.Shape()[2] != 2 {
        Errorf("MaxPool2D output height should be 2")
    }
    if out.Shape()[3] != 2 {
        Errorf("MaxPool2D output width should be 2")
    }
}

// TestFlatten verifies shape is reduced to 2D.
pub fn TestFlatten() {
    a := tensor.Zeros([2, 3, 4])
    f := tensor.Flatten(a)
    if f.Rank() != 2 {
        Errorf("Flatten should produce rank 2")
    }
    if f.Shape()[0] != 2 {
        Errorf("Flatten batch should be 2")
    }
    if f.Shape()[1] != 12 {
        Errorf("Flatten features should be 3*4=12")
    }
}

// TestMSELoss verifies loss for identical tensors is 0.
pub fn TestMSELoss() {
    a := tensor.Ones([2, 2])
    loss := tensor.MSELoss(a, a)
    if loss != 0.0 {
        Errorf("MSELoss of identical tensors should be 0")
    }
}
