// Module time_test contains unit tests for the std/time module.
module time_test

import "std/time"
import "testing"

// TestTimestamp verifies that the current Unix timestamp is positive.
pub fn TestTimestamp() {
    ts := time.Timestamp()
    if ts <= 0 {
        Errorf("Timestamp should be positive")
    }
}

// TestNowUnixNano verifies nanosecond timestamp is positive.
pub fn TestNowUnixNano() {
    ns := time.NowUnixNano()
    if ns <= int64(0) {
        Errorf("NowUnixNano should be positive")
    }
}

// TestDurationFromSeconds verifies Duration creation.
pub fn TestDurationFromSeconds() {
    d := time.Duration.FromSeconds(5)
    if d.Seconds() != 5.0 {
        Errorf("Duration from seconds should be 5")
    }
}

// TestDateTimeNow verifies Now returns a valid year.
pub fn TestDateTimeNow() {
    dt := time.DateTime.Now()
    if dt.Year() < 2026 {
        Errorf("Current year should be >= 2026")
    }
    if dt.Month() < 1 || dt.Month() > 12 {
        Errorf("Month should be in range 1-12")
    }
    if dt.Day() < 1 || dt.Day() > 31 {
        Errorf("Day should be in range 1-31")
    }
}

// TestDurationNanoseconds verifies nanosecond accessor.
pub fn TestDurationNanoseconds() {
    d := time.Duration.FromMilliseconds(1500)
    if d.Milliseconds() != int64(1500) {
        Errorf("Duration milliseconds should be 1500")
    }
}

// TestDateTimeUnixRoundtrip verifies Unix timestamp roundtrip.
pub fn TestDateTimeUnixRoundtrip() {
    dt := time.DateTime.Now()
    unix := dt.Unix()
    dt2 := time.DateTime.FromUnix(unix)
    if dt2.Unix() != unix {
        Errorf("Unix roundtrip should preserve timestamp")
    }
}
