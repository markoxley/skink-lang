// Module waitgroup_test contains unit tests for the std/waitgroup module.
// These tests exercise single-threaded behaviour only.  Concurrent
// (multi-goroutine) correctness is verified by the Go integration tests
// in compiler/codegen/integration_test.go.
module waitgroup_test

import "std/waitgroup"
import "testing"

// TestWaitGroupNew verifies that New() returns a valid WaitGroup
// whose Wait() returns immediately (fast path for count == 0).
pub fn TestWaitGroupNew() {
    wg := waitgroup.New()
    wg.Wait()
}

// TestWaitGroupDoneOnZero verifies that calling Done() when the
// counter is already zero does not panic or misbehave.
pub fn TestWaitGroupDoneOnZero() {
    wg := waitgroup.New()
    wg.Done()
    wg.Done()
    wg.Wait()
}

// TestWaitGroupAddDoneSequence verifies that Add followed by Done
// brings the counter back to zero so that Wait returns without
// blocking.
pub fn TestWaitGroupAddDoneSequence() {
    wg := waitgroup.New()
    wg.Add(1)
    wg.Done()
    wg.Wait()
}

// TestWaitGroupMultipleAddDone verifies that multiple Add / Done
// pairs are tracked correctly.
pub fn TestWaitGroupMultipleAddDone() {
    wg := waitgroup.New()
    wg.Add(3)
    wg.Done()
    wg.Done()
    wg.Done()
    wg.Wait()
}
