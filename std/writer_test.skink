// Module writer_test tests the Writer template with a concrete buf.Buffer.
module writer_test

import "std/writer"
import "std/buf"
import "std/libc"
import "std/str"
import "testing"

// TestWriteString verifies writer.WriteString with a buf.Buffer.
pub fn TestWriteString() {
    b := buf.NewBuffer()
    n := writer.WriteString(&b, "hello")
    if n != 5 {
        Errorf("WriteString should return 5 for hello")
    }
    s := b.String()
    if str.Equal(s, "hello") == false {
        Errorf("WriteString should write hello to buffer")
    }
    libc.free(s)
    b.Free()
}
