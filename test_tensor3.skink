module main

import "std/tensor"

fn main() -> int {
    print("Testing tensor...")
    
    t := tensor.Zeros([2, 3])
    print("Created tensor")
    
    shape := t.Shape()
    print("Shape: {shape[0]} x {shape[1]}")
    print("Rank: {t.Rank()}")
    
    t.Set([0, 0], 1.0)
    val := t.Get([0, 0])
    print("Value at [0,0]: {val}")
    
    print("All tensor operations work!")
    return 0
}
